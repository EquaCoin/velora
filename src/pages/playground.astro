---
const title = "Velora Playground • Prova subito il linguaggio";
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: radial-gradient(circle at center, #0A0A1F 0%, #000000 100%); }
    .active { background-color: #a020f0 !important; }
  </style>
</head>
<body class="text-white font-sans">
  <div class="min-h-screen p-8">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="flex justify-between items-center mb-8">
        <a href="/" class="flex items-center gap-3 text-3xl font-bold" style="color: #ffffff; text-shadow: 0 0 40px #00F5FF;">
          <img src="/logo.png" class="w-12" alt="Velora">
          VELORA
        </a>
        <h1 style="color: #ffffff; text-shadow: 0 0 40px #00F5FF;" class="text-4xl font-bold">Playground</h1>
      </div>

      <!-- Pulsanti esempi -->
      <div id="examples" class="flex flex-wrap gap-3 mb-6 justify-center">
        <!-- riempiti dal JS -->
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Editor -->
        <div>
          <h2 style="color: #ffffff;" class="text-xl mb-3">Scrivi codice Velora</h2>
          <textarea id="code" class="w-full h-96 p-6 font-mono text-lg resize-none rounded-3xl" 
                    style="background: #05050F; border: 3px solid #00F5FF; box-shadow: 0 0 40px #00F5FF; color: #67E8F9 !important;" 
                    spellcheck="false"></textarea>
        </div>

        <!-- Output -->
        <div>
          <div class="flex justify-between mb-3">
            <h2 style="color: #ffffff;" class="text-xl">Output</h2>
            <button id="run-btn" 
                    class="px-8 py-3 bg-gradient-to-r from-purple-600 to-cyan-500 rounded-2xl font-bold text-xl hover:scale-105 transition">
              ▶️ Run
            </button>
          </div>
          <div id="output" class="w-full h-96 p-6 font-mono text-lg rounded-3xl overflow-auto" 
               style="background: #05050F; border: 3px solid #00F5FF; box-shadow: 0 0 40px #00F5FF; color: #ffffff !important;">
            Seleziona un esempio e clicca Run!
          </div>
        </div>
      </div>

      <p style="color: #ffffff; text-shadow: 0 0 20px #67E8F9;" class="mt-12 text-center">Mock interattivo • Il vero compilatore arriverà in v1.1</p>
    </div>
  </div>

  <script>
    const examples = [
      {name: "Hello World", code: `main:\n    print("Ciao mondo! Velora è viva 🚀")`, output: "Ciao mondo! Velora è viva 🚀"},
      {name: "Fibonacci", code: `fn fibonacci(n: Int) -> Int:\n    match n:\n        0: 0\n        1: 1\n        _: fibonacci(n-1) + fibonacci(n-2)\n\nprint(fibonacci(10))`, output: "Fibonacci(10) = 55"},
      {name: "Actor Bank", code: `actor BankAccount:\n    balance: Float = 0.0\n\n    on deposit(amount: Float):\n        balance += amount\n        reply "Deposited!"`, output: "Deposited! (saldo aggiornato)"},
      {name: "Parallel", code: `async fn process_batch(items: [Data]) -> [Result]:\n    results = parallel:\n        for item in items:\n            await heavy_computation(item)`, output: "Elaborati 8 item in parallelo"},
      {name: "AI Feature", code: `# AI: crea una classe User\nuser_model = ai "classe User con validazione email e password hash"`, output: "Classe User generata automaticamente dall'AI!"}
    ];

    let currentIndex = 0;

    function loadExample(index) {
      currentIndex = index;
      document.getElementById('code').value = examples[index].code;
      
      // evidenzia il pulsante attivo
      document.querySelectorAll('#examples button').forEach((btn, i) => {
        btn.classList.toggle('active', i === index);
      });
    }

    function runCode() {
      const output = document.getElementById('output');
      const result = examples[currentIndex].output;
      output.innerHTML = `<span style="color:#67E8F9;">✓ Compilato in 0.03s</span><br><br>Output:<br>${result}<br><br>🎉 Tutto perfetto!`;
      output.style.color = '#ffffff';
    }

    // Crea i pulsanti dinamicamente
    function createButtons() {
      const container = document.getElementById('examples');
      examples.forEach((ex, i) => {
        const btn = document.createElement('button');
        btn.textContent = ex.name;
        btn.className = "px-6 py-3 bg-purple-600 hover:bg-purple-700 rounded-2xl font-bold text-sm transition";
        btn.onclick = () => loadExample(i);
        container.appendChild(btn);
      });
      loadExample(0); // primo esempio attivo
    }

    // Run button
    document.getElementById('run-btn').addEventListener('click', runCode);

    window.onload = createButtons;
  </script>
</body>
</html>
