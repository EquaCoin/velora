---
const title = "Velora • Pensa come un umano, compila come un divo";
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: radial-gradient(circle at center, #0A0A1F 0%, #000000 100%); }
  </style>
</head>
<body class="text-white font-sans overflow-x-hidden">
  <!-- NAVIGAZIONE -->
  <nav class="flex justify-center gap-8 py-6 text-lg font-medium border-b border-cyan-500/30">
    <a href="/" class="hover:text-cyan-300 transition">Home</a>
    <a href="/docs" class="hover:text-cyan-300 transition">Docs</a>
    <a href="/playground" class="hover:text-cyan-300 transition">Playground</a>
  </nav>

  <div class="min-h-screen flex flex-col items-center justify-center px-6 py-12">
    <!-- LOGO A METÀ DIMENSIONI (70px) -->
    <div class="text-center mb-8">
      <img src="/logo.png" alt="Velora Logo" class="mx-auto w-[70px] drop-shadow-[0_0_60px_#00F5FF] drop-shadow-[0_0_120px_#A020F0]">
      <p style="color: #67E8F9;" class="text-2xl mt-4">v1.0 • AI-Native Programming Language</p>
    </div>

    <!-- resto del codice homepage rimane identico -->
    <!-- (headline, blocco codice, bottoni, footer) -->
    <!-- ... copia-incolla il resto dalla versione precedente se vuoi, oppure dimmi e te lo mando completo -->
  </div>
</body>
</html>
