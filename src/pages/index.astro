---
const title = "Velora • Pensa come un umano, compila come un divo";
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: radial-gradient(circle at center, #0A0A1F 0%, #000000 100%); }
  </style>
</head>
<body class="text-white font-sans overflow-x-hidden">
  <div class="min-h-screen flex flex-col items-center justify-center px-6 py-12">
    <!-- V ENORME BIANCO PURO -->
    <div class="text-center mb-6">
      <div style="font-size: 14rem; line-height: 0.8; color: #ffffff; text-shadow: 0 0 80px #00F5FF, 0 0 160px #A020F0, 0 0 300px #ffffff;" class="font-black tracking-[-0.08em]">V</div>
      <h1 style="color: #ffffff; text-shadow: 0 0 60px #00F5FF, 0 0 120px #A020F0, 0 0 200px #ffffff;" class="text-7xl font-bold tracking-tighter -mt-8">VELORA</h1>
      <p style="color: #67E8F9;" class="text-2xl mt-2">v1.0 • AI-Native Programming Language</p>
    </div>

    <!-- HEADLINE AGGIORNATA -->
    <h2 style="color: #ffffff; text-shadow: 0 0 60px #00F5FF, 0 0 120px #A020F0, 0 0 200px #ffffff;" class="text-6xl font-bold text-center max-w-4xl mb-16 leading-none">
      Pensa come un umano,<br>
      compila come un divo
    </h2>

    <!-- Blocco codice (già perfetto) -->
    <div class="bg-[#05050F] border-4 border-[#00F5FF] rounded-3xl p-10 max-w-3xl w-full" style="box-shadow: 0 0 60px #00F5FF;">
      <pre class="overflow-x-auto"><code>main:
    print("Ciao mondo! Velora è viva 🚀")

fn fibonacci(n: Int) -> Int:
    match n:
        0: 0
        1: 1
        _: fibonacci(n-1) + fibonacci(n-2)

# AI: crea una REST API completa
api = ai "REST API per utenti con JWT e validazione"</code></pre>
    </div>

    <div class="mt-16 flex flex-col sm:flex-row gap-8 w-full max-w-xl">
      <a href="https://github.com/EquaCoin/velora/releases" class="flex-1 px-12 py-7 bg-gradient-to-r from-purple-600 to-cyan-500 text-center rounded-3xl font-bold text-2xl hover:scale-110">↓ Download Velora v1.0</a>
      <a href="#" class="flex-1 px-12 py-7 border-4 border-cyan-400 text-[#67E8F9] text-center rounded-3xl font-bold text-2xl hover:bg-cyan-400/10">Prova il Playground</a>
    </div>

    <!-- FOOTER BIANCO LUMINOSO -->
    <p style="color: #ffffff; text-shadow: 0 0 30px #67E8F9;" class="mt-24 text-lg flex items-center gap-3">
      Built with ❤️ in Rome 
      <span class="text-2xl">🇮🇹</span> 
      • velora-lang.uk • 16 Marzo 2026
    </p>
  </div>
</body>
</html>
