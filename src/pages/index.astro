---
const title = "Velora • Pensa come un umano, compila come un dio";
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { 
      background: radial-gradient(circle at center, #0A0A1F 0%, #000000 100%); 
    }
    .velora-glow { 
      text-shadow: 0 0 60px #00F5FF, 0 0 120px #A020F0, 0 0 180px #FFD700; 
    }
    .big-v {
      font-size: 14rem;
      line-height: 0.8;
      background: linear-gradient(45deg, #A020F0, #00F5FF, #FFD700);
      -webkit-background-clip: text;
      color: transparent;
    }
    .code-block {
      background: #0F0F1A;
      border: 3px solid #00F5FF;
      box-shadow: 0 0 50px #00F5FF;
    }
    pre { 
      color: #67E8F9; 
      font-size: 1.2rem;
      line-height: 1.7;
    }
  </style>
</head>
<body class="text-white font-sans overflow-x-hidden">
  <div class="min-h-screen flex flex-col items-center justify-center px-6 py-12">
    <!-- Logo V ufficiale ENORME -->
    <div class="text-center mb-6">
      <div class="big-v font-black tracking-[-0.08em] velora-glow">V</div>
      <h1 class="text-7xl font-bold velora-glow tracking-tighter -mt-8">VELORA</h1>
      <p class="text-2xl mt-2 text-cyan-300">v1.0 • AI-Native Programming Language</p>
    </div>

    <h2 class="text-6xl font-bold text-center max-w-4xl velora-glow mb-16 leading-none">
      Pensa come un umano,<br>
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-purple-400 via-cyan-300 to-yellow-300">compila come un dio</span>
    </h2>

    <!-- Blocco codice ULTRA PREMIUM -->
    <div class="code-block rounded-3xl p-10 max-w-3xl w-full overflow-hidden">
      <pre class="overflow-x-auto"><code>main:
    print("Ciao mondo! Velora è viva 🚀")

fn fibonacci(n: Int) -> Int:
    match n:
        0: 0
        1: 1
        _: fibonacci(n-1) + fibonacci(n-2)

# AI: crea una REST API completa
api = ai "REST API per utenti con JWT e validazione"</code></pre>
    </div>

    <div class="mt-16 flex flex-col sm:flex-row gap-8 w-full max-w-xl">
      <a href="https://github.com/EquaCoin/velora/releases" 
         class="flex-1 px-12 py-7 bg-gradient-to-r from-purple-600 to-cyan-500 text-center rounded-3xl font-bold text-2xl hover:scale-110 hover:shadow-2xl transition-all">
        ↓ Download Velora v1.0
      </a>
      <a href="#" 
         class="flex-1 px-12 py-7 border-4 border-cyan-400 text-cyan-300 text-center rounded-3xl font-bold text-2xl hover:bg-cyan-400/10 transition-all">
        Prova il Playground
      </a>
    </div>

    <p class="mt-24 text-lg text-cyan-400 flex items-center gap-3">
      Built with ❤️ in Rome 
      <span class="text-2xl">🇮🇹</span> 
      • velora-lang.uk • 16 Marzo 2026
    </p>
  </div>
</body>
</html>
