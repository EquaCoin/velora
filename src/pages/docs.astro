---
const title = "Velora Docs • v2.0";
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: radial-gradient(circle at center, #0A0A1F 0%, #000000 100%); }
    .glow { text-shadow: 0 0 40px #00F5FF; }
  </style>
</head>
<body class="text-white font-sans">
  <div class="max-w-4xl mx-auto p-8">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-12">
      <img src="/logo.png" class="w-16" alt="Velora">
      <div>
        <h1 class="text-5xl font-bold glow">Velora Docs</h1>
        <p class="text-cyan-300 text-xl">v2.0 • AI-Native Programming Language</p>
      </div>
    </div>

    <h2 class="text-3xl font-bold mb-8">Installazione</h2>
    <div class="bg-[#05050F] p-6 rounded-3xl mb-12">
      <pre><code>cd ~/Velora
python3 velora.py run test.vel</code></pre>
    </div>

    <h2 class="text-3xl font-bold mb-8">Sintassi Base</h2>
    <ul class="space-y-6 text-lg">
      <li><strong>main:</strong> punto di ingresso</li>
      <li><strong>print()</strong> – output</li>
      <li><strong>let x = ...</strong> – variabile immutabile</li>
      <li><strong>fn nome(...)</strong> – funzioni</li>
      <li><strong>match</strong> – pattern matching</li>
    </ul>

    <h2 class="text-3xl font-bold mt-16 mb-8">Esempi Completi</h2>

    <div class="space-y-12">
      <!-- Hello World -->
      <div>
        <h3 class="text-2xl font-bold text-cyan-300 mb-3">1. Hello World</h3>
        <pre class="bg-[#05050F] p-6 rounded-3xl text-cyan-300"><code>main:
    print("Ciao mondo! Velora è viva 🚀")</code></pre>
      </div>

      <!-- Fibonacci -->
      <div>
        <h3 class="text-2xl font-bold text-cyan-300 mb-3">2. Fibonacci</h3>
        <pre class="bg-[#05050F] p-6 rounded-3xl text-cyan-300"><code>fn fibonacci(n: Int) -> Int:
    match n:
        0: 0
        1: 1
        _: fibonacci(n-1) + fibonacci(n-2)

print(fibonacci(10))</code></pre>
      </div>

      <!-- Actor -->
      <div>
        <h3 class="text-2xl font-bold text-cyan-300 mb-3">3. Actor (concurrency sicura)</h3>
        <pre class="bg-[#05050F] p-6 rounded-3xl text-cyan-300"><code>actor BankAccount:
    balance: Float = 0.0

    on deposit(amount: Float):
        balance += amount

BankAccount << deposit(100)</code></pre>
      </div>

      <!-- Parallel -->
      <div>
        <h3 class="text-2xl font-bold text-cyan-300 mb-3">4. Parallelismo</h3>
        <pre class="bg-[#05050F] p-6 rounded-3xl text-cyan-300"><code>async fn process():
    parallel:
        print("Task 1")
        print("Task 2")</code></pre>
      </div>

      <!-- AI -->
      <div>
        <h3 class="text-2xl font-bold text-cyan-300 mb-3">5. AI Feature</h3>
        <pre class="bg-[#05050F] p-6 rounded-3xl text-cyan-300"><code># AI: crea una classe User
user_model = ai "classe User con validazione email e password hash"</code></pre>
      </div>
    </div>

    <h2 class="text-3xl font-bold mt-16 mb-8">CLI</h2>
    <pre class="bg-[#05050F] p-6 rounded-3xl"><code>python3 velora.py run file.vel</code></pre>

    <p class="mt-16 text-center text-cyan-400">Built with ❤️ in Rome • velora-lang.uk • 16 Marzo 2026</p>
  </div>
</body>
</html>
