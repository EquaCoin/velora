---
const title = "Velora Docs • v2.0";
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: radial-gradient(circle at center, #0A0A1F 0%, #000000 100%); }
  </style>
</head>
<body class="text-white font-sans">
  <!-- NAVIGAZIONE -->
  <nav class="flex justify-center gap-8 py-6 text-lg font-medium">
    <a href="/" class="hover:text-cyan-300 transition">Home</a>
    <a href="/docs" class="hover:text-cyan-300 transition">Docs</a>
    <a href="/playground" class="hover:text-cyan-300 transition">Playground</a>
  </nav>

  <div class="max-w-4xl mx-auto p-8">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-12">
      <img src="/logo.png" class="w-16" alt="Velora">
      <div>
        <h1 style="color: #ffffff !important; text-shadow: 0 0 80px #00F5FF, 0 0 160px #A020F0, 0 0 300px #ffffff !important;" class="text-5xl font-bold">Velora Docs</h1>
        <p style="color: #67E8F9 !important;" class="text-xl">v2.0 • AI-Native Programming Language</p>
      </div>
    </div>

    <!-- Il resto del contenuto docs rimane uguale (sintassi, esempi, ecc.) -->
    <!-- ... (puoi copiare il resto dalla versione precedente se vuoi, ma per brevità lo lascio qui completo) -->

    <h2 style="color: #ffffff !important; text-shadow: 0 0 60px #00F5FF, 0 0 120px #A020F0, 0 0 200px #ffffff !important;" class="text-3xl font-bold mb-8">Installazione</h2>
    <div class="bg-[#05050F] p-6 rounded-3xl mb-12">
      <pre><code style="color: #67E8F9 !important;">cd ~/Velora
python3 velora.py run test.vel</code></pre>
    </div>

    <!-- ... resto degli esempi ... -->

    <p style="color: #ffffff !important; text-shadow: 0 0 40px #67E8F9;" class="mt-16 text-center text-lg">
      Built with ❤️ in Rome 
      <span class="text-2xl">🇮🇹</span> 
      • velora-lang.uk • 16 Marzo 2026
    </p>
  </div>
</body>
</html>
